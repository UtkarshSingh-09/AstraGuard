APP_NAME=AstraGuard Backend
APP_ENV=dev
APP_DEBUG=true

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-host>/astraguard?retryWrites=true&w=majority

MONGODB_DB_NAME=astraguard
MONGODB_ATLAS_REQUIRED=true

REDIS_URL=redis://default:<password>@<redis-host>:<port>/0


JOBS_TTL_SECONDS=1800

SEBI_DISCLAIMER=AI-generated guidance for educational purposes only. Not licensed financial advice under SEBI IA Regulations.

CAS_PROVIDER_ENABLED=false
CAS_PROVIDER_NAME=cas_provider
CAS_PROVIDER_BASE_URL=
CAS_PROVIDER_API_KEY=

GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_TIMEOUT_SECONDS=20
